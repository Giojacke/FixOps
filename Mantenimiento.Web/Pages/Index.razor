@page "/"
@using Mantenimiento.Application.DTOs
@using Mantenimiento.Domain.Enums
@using Mantenimiento.Web.Services
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@inject OrdenTrabajoClient OrdenTrabajoClient
@inject AuthenticationStateProvider AuthStateProvider
@attribute [Authorize]

<style>
    .modal-overlay { position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,.5);z-index:1050;display:flex;align-items:center;justify-content:center; }
    .modal-box     { background:#fff;border-radius:8px;padding:24px;min-width:360px;max-width:500px;width:90%;box-shadow:0 8px 32px rgba(0,0,0,.3); }
</style>

<PageTitle>Órdenes de Mantenimiento</PageTitle>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1>Órdenes de Mantenimiento</h1>
        <AuthorizeView Roles="Administrador, Solicitante">
            <a href="registrar-orden" class="btn btn-primary">
                <i class="bi bi-plus-circle me-1"></i>Nueva Orden
            </a>
        </AuthorizeView>
    </div>

    <!-- ===== FILTROS ===== -->
    <AuthorizeView Roles="Administrador, Solicitante">
        <div class="card shadow-sm mb-4">
            <div class="card-body py-2">
                <div class="row g-2 align-items-end">
                    <div class="col-md-2">
                        <label class="form-label fw-semibold mb-1 small">Estado</label>
                        <select class="form-select form-select-sm" @bind="_filtroEstado">
                            <option value="">Todos</option>
                            @foreach (var e in Enum.GetValues<EstadoOrden>())
                            { <option value="@e">@e</option> }
                        </select>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label fw-semibold mb-1 small">Urgencia</label>
                        <select class="form-select form-select-sm" @bind="_filtroUrgencia">
                            <option value="">Todas</option>
                            @foreach (var u in Enum.GetValues<NivelUrgencia>())
                            { <option value="@u">@u</option> }
                        </select>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label fw-semibold mb-1 small">Folio</label>
                        <input class="form-control form-control-sm" placeholder="OT-..."
                               @bind="_filtroFolio" @bind:event="oninput"
                               @onkeyup="OnFolioKeyUp" />
                    </div>
                    <div class="col-md-2">
                        <label class="form-label fw-semibold mb-1 small">Desde</label>
                        <input type="date" class="form-control form-control-sm" @bind="_filtroDesde" />
                    </div>
                    <div class="col-md-2">
                        <label class="form-label fw-semibold mb-1 small">Hasta</label>
                        <input type="date" class="form-control form-control-sm" @bind="_filtroHasta" />
                    </div>
                    <div class="col-md-2 d-flex gap-1">
                        <button class="btn btn-primary btn-sm flex-grow-1" @onclick="Buscar">
                            <i class="bi bi-search me-1"></i>Buscar
                        </button>
                        <button class="btn btn-outline-secondary btn-sm" title="Limpiar filtros" @onclick="Limpiar">
                            <i class="bi bi-x-lg"></i>
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </AuthorizeView>

    <!-- ===== TABLA ===== -->
    @if (_cargando)
    {
        <p><span class="spinner-border spinner-border-sm me-2"></span>Cargando...</p>
    }
    else if (!(_ordenes?.Any() ?? false))
    {
        <div class="alert alert-info">No hay órdenes que coincidan con los filtros.</div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>Folio</th>
                        <th>Descripción</th>
                        <th>Dependencia</th>
                        <th>Técnico</th>
                        <th>Estado</th>
                        <th>Urgencia</th>
                        <th>Fecha</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var orden in _ordenes!)
                    {
                        <tr>
                            <td class="fw-semibold text-nowrap">@orden.Folio</td>
                            <td style="max-width:200px" class="text-truncate" title="@orden.Descripcion">@orden.Descripcion</td>
                            <td>@orden.DependenciaNombre</td>
                            <td>@(string.IsNullOrEmpty(orden.TecnicoAsignadoNombre) || orden.TecnicoAsignadoNombre == "Sin asignar" ? "—" : orden.TecnicoAsignadoNombre)</td>
                            <td><span class="badge @GetEstadoBadgeClass(orden.Estado)">@orden.Estado</span></td>
                            <td><span class="badge @GetUrgenciaBadgeClass(orden.Urgencia)">@orden.Urgencia</span></td>
                            <td class="text-nowrap">@orden.FechaCreacion.ToLocalTime().ToString("dd/MM/yy HH:mm")</td>
                            <td>
                                <div class="btn-group btn-group-sm">

                                    <!-- Ver / Gestionar operaciones -->
                                    <a href="añadir-operacion/@orden.Id"
                                       class="btn @(orden.Estado is EstadoOrden.Finalizada or EstadoOrden.Cancelada ? "btn-outline-secondary" : "btn-outline-primary")"
                                       title="@(orden.Estado is EstadoOrden.Finalizada or EstadoOrden.Cancelada ? "Ver operaciones" : "Gestionar operaciones")">
                                        <i class="bi @(orden.Estado is EstadoOrden.Finalizada or EstadoOrden.Cancelada ? "bi-eye" : "bi-tools")"></i>
                                    </a>

                                    <!-- Encuesta: Finalizada + sin encuesta respondida -->
                                    @if (orden.Estado == EstadoOrden.Finalizada && !orden.TieneEncuesta)
                                    {
                                        <AuthorizeView Roles="Administrador,Solicitante,Programador">
                                            <a href="encuesta/@orden.Id" class="btn btn-success" title="Calificar servicio">
                                                <i class="bi bi-star-fill"></i>
                                            </a>
                                        </AuthorizeView>
                                    }
                                    @if (orden.Estado == EstadoOrden.Finalizada && orden.TieneEncuesta)
                                    {
                                        <span class="btn btn-outline-success disabled" title="Encuesta ya respondida">
                                            <i class="bi bi-star-fill"></i>
                                        </span>
                                    }

                                    <!-- Cancelar: solo Administrador, solo órdenes activas -->
                                    @if (orden.Estado != EstadoOrden.Finalizada && orden.Estado != EstadoOrden.Cancelada)
                                    {
                                        <AuthorizeView Roles="Administrador">
                                            <button class="btn btn-outline-danger" title="Cancelar orden"
                                                    @onclick="() => PedirConfirmCancelar(orden)">
                                                <i class="bi bi-x-circle"></i>
                                            </button>
                                        </AuthorizeView>
                                    }

                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <div class="text-muted small">@_ordenes!.Count() resultado(s)</div>
    }

    @if (!string.IsNullOrEmpty(_mensaje))
    {
        <div class="alert alert-@_mensajeTipo mt-3 alert-dismissible">
            @_mensaje
            <button type="button" class="btn-close" @onclick="() => _mensaje = null"></button>
        </div>
    }
</div>

<!-- ===== MODAL CONFIRMAR CANCELAR ===== -->
@if (_confirm)
{
    <div class="modal-overlay">
        <div class="modal-box">
            <h5 class="mb-3"><i class="bi bi-exclamation-triangle-fill text-warning me-2"></i>Confirmar cancelación</h5>
            <p>@_confirmMsg</p>
            <div class="d-flex justify-content-end gap-2">
                <button class="btn btn-outline-secondary" @onclick="() => _confirm = false">No, volver</button>
                <button class="btn btn-danger" @onclick="EjecutarCancelar">Sí, cancelar orden</button>
            </div>
        </div>
    </div>
}

@code {
    private IEnumerable<OrdenTrabajoDto>? _ordenes;
    private bool    _cargando;
    private string? _mensaje;
    private string  _mensajeTipo = "success";

    // Filtros
    private string    _filtroEstado   = string.Empty;
    private string    _filtroUrgencia = string.Empty;
    private string    _filtroFolio    = string.Empty;
    private DateTime? _filtroDesde;
    private DateTime? _filtroHasta;

    // Confirmación cancelar
    private bool   _confirm;
    private string _confirmMsg     = string.Empty;
    private Guid   _ordenACancelar;

    protected override async Task OnInitializedAsync() => await Buscar();

    private async Task Buscar()
    {
        _cargando = true;
        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;

            if (user.IsInRole("Tecnico"))
            {
                var userId = user.FindFirst(ClaimTypes.NameIdentifier)?.Value;
                _ordenes = Guid.TryParse(userId, out var guid)
                    ? await OrdenTrabajoClient.GetByTecnicoAsync(guid)
                    : [];
            }
            else
            {
                _ordenes = await OrdenTrabajoClient.GetAllAsync(
                    estado:   string.IsNullOrEmpty(_filtroEstado)   ? null : _filtroEstado,
                    urgencia: string.IsNullOrEmpty(_filtroUrgencia) ? null : _filtroUrgencia,
                    folio:    string.IsNullOrEmpty(_filtroFolio)    ? null : _filtroFolio,
                    desde:    _filtroDesde,
                    hasta:    _filtroHasta);
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error al cargar órdenes: {ex.Message}");
            _ordenes = [];
        }
        _cargando = false;
    }

    private async Task Limpiar()
    {
        _filtroEstado = _filtroUrgencia = _filtroFolio = string.Empty;
        _filtroDesde = _filtroHasta = null;
        await Buscar();
    }

    private async Task OnFolioKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await Buscar();
    }

    // ---------- CANCELAR ----------
    private void PedirConfirmCancelar(OrdenTrabajoDto orden)
    {
        _ordenACancelar = orden.Id;
        _confirmMsg     = $"¿Cancelar la orden {orden.Folio}? Esta acción no se puede deshacer.";
        _confirm        = true;
    }

    private async Task EjecutarCancelar()
    {
        _confirm = false;
        var result = await OrdenTrabajoClient.ActualizarEstadoOrdenAsync(_ordenACancelar, EstadoOrden.Cancelada);
        if (result.IsSuccess)
        {
            _mensaje     = "Orden cancelada correctamente.";
            _mensajeTipo = "success";
            await Buscar();
        }
        else
        {
            _mensaje     = result.ErrorMessage ?? "Error al cancelar la orden.";
            _mensajeTipo = "danger";
        }
    }

    // ---------- BADGES ----------
    private string GetEstadoBadgeClass(EstadoOrden estado) => estado switch
    {
        EstadoOrden.Pendiente  => "bg-warning text-dark",
        EstadoOrden.EnProceso  => "bg-info text-dark",
        EstadoOrden.Finalizada => "bg-success",
        EstadoOrden.Cancelada  => "bg-danger",
        _ => "bg-secondary"
    };

    private string GetUrgenciaBadgeClass(NivelUrgencia urgencia) => urgencia switch
    {
        NivelUrgencia.Baja    => "bg-secondary",
        NivelUrgencia.Media   => "bg-primary",
        NivelUrgencia.Alta    => "bg-warning text-dark",
        NivelUrgencia.Critica => "bg-danger",
        _ => "bg-dark"
    };
}
